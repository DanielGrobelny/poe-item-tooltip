{
  "name": "@danielgrobelny/poe-item-tooltip",
  "version": "0.1.0",
  "description": "React component library for rendering Path of Exile item tooltips",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "build:demo": "vite build --config vite.config.demo.ts"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^24.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-dts": "^4.0.2",
    "vitest": "^2.0.3"
  },
  "keywords": ["path-of-exile", "poe", "tooltip", "react", "component"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danielgrobelny/poe-item-tooltip"
  }
}
